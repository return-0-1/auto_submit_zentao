# 环境变量配置文件示例
# 将此文件复制为 .env 并填写实际值

# 禅道登录配置
ZENTAO_USERNAME=your_username
ZENTAO_PASSWORD=your_password

# GPT API 配置
GPT_API_KEY=your_api_key_here

# GPT服务提供商配置（可选，默认 deepseek）
# 可选值: deepseek 或 qwen
GPT_PROVIDER=deepseek

# Qwen GPT 配置（当 GPT_PROVIDER=qwen 时使用）
QWEN_MODEL=Qwen3-14B
QWEN_API_URL=http://192.168.7.70:5001/v1/chat-messages
QWEN_API_KEY=your_Qwen_api_key_here
QWEN_USER=tester1

# 路径配置（可选，默认使用 constants.py 中的值）
# DRIVER_PATH=C:\\path\\to\\msedgedriver.exe
# DOWNLOAD_FOLDER=D:\\VayoPro\\需求方案\\down
# OUTPUT_BASE_FOLDER=D:\\VayoPro\\需求方案\\mid
# JSON_DATA_PATH=D:\\VayoPro\\需求方案\\gpt_output\\