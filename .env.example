# 环境变量配置文件示例
# 将此文件复制为 .env 并填写实际值

# ============ 禅道登录配置 ============
ZENTAO_USERNAME=your_username
ZENTAO_PASSWORD=your_password

# ============ GPT API 配置 ============
GPT_API_KEY=your_api_key_here

# GPT服务提供商配置（可选，默认 deepseek）
# 可选值: deepseek 或 qwen
GPT_PROVIDER=deepseek

# Qwen GPT 配置（当 GPT_PROVIDER=qwen 时使用）
QWEN_MODEL=Qwen3-14B
QWEN_API_URL=http://192.168.7.70:5001/v1/chat-messages
QWEN_API_KEY=your_Qwen_api_key_here
QWEN_USER=tester1

# GPT 提示词文件路径
GPT_PROMPT_FILE=prompt.txt

# ============ 调试模式配置 ============
# 设为 true 时，表单提交操作将仅输出日志，不真正提交
DEBUG_MODE=false

# ============ URL 配置 ============
# 禅道服务器基础地址
ZENTAO_BASE_URL=http://192.168.7.3:82
# 测试用例创建URL
CASE_URL=http://192.168.7.3:82/index.php?m=testcase&f=create&productID=4&branch=0&moduleID=0
# 缺陷创建URL
BUG_URL=http://vxian.synology.me:82/index.php?m=bug&f=create&productID=33&branch=0&extra=moduleID=0
# 需求查看URL
NEED_URL=http://192.168.7.3:82/index.php?m=story&f=view&t=html&id=

# ============ 路径配置 ============
# Edge浏览器驱动路径
DRIVER_PATH=C:\\Users\\V072\\.wdm\\drivers\\edgedriver\\win64\\msedgedriver.exe
# 下载文件夹路径
DOWNLOAD_FOLDER=D:\\VayoPro\\需求方案\\down
# 输出基础文件夹路径
OUTPUT_BASE_FOLDER=D:\\VayoPro\\需求方案\\mid
# JSON数据文件夹路径
JSON_DATA_PATH=D:\\VayoPro\\需求方案\\gpt_output\\

# ============ 默认配置 ============
# 默认模块
DEFAULT_MODULE=/
# 默认提交类型（case 或 bug）
DEFAULT_SUBMIT_TYPE=case
# 默认需求ID列表（多个ID用逗号分隔）
DEFAULT_STORY_ID_LIST=3509